# Copy this file to .env and fill in values before running.

# Anthropic API key — used by the ingestion pipeline for entity extraction (Haiku)
ANTHROPIC_API_KEY=your_key_here

# Neo4j password — must match NEO4J_AUTH in docker-compose.yml
NEO4J_PASSWORD=your_neo4j_password_here

# Service URLs — defaults work if running via docker-compose + local Ollama
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
OLLAMA_BASE_URL=http://localhost:11434

# Retrieval tuning
VECTOR_WEIGHT=0.6
GRAPH_WEIGHT=0.4
DEFAULT_RETRIEVE_LIMIT=10
